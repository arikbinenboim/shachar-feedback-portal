# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Google OAuth (same client as the debrief form — just add the new Vercel URL as redirect URI)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Leave empty to allow any Google account to fill feedback forms
ALLOWED_EMAILS=

# Supabase (same project as debrief form, different tables)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx
